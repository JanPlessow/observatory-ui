{
  "name": "observatory-ui",
  "version": "0.1.0",
  "description": "The Observatory — shared design system (tokens + primitives) for Polaris and its apps.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": ["src"],
  "sideEffects": ["*.css"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^6",
    "typescript-eslint": "^8.62.0"
  }
}
